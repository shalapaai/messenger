{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/messenger-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },

  "ConnectionStrings": {
    "MessengerDb": "Host=localhost;Port=5432;Database=messenger;Username=postgres;Password=your_password"
  },

  "Jwt": {
    "SecretKey": "your-super-secret-key-minimum-256-bits-long-change-in-production",
    "Issuer": "Messenger.Api",
    "Audience": "Messenger.Client",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 30
  },

  "Redis": {
    "ConnectionString": "localhost:6379,abortConnect=false"
  },

  "Files": {
    "StoragePath": "/var/messenger/uploads",
    "MaxFileSizeBytes": 52428800,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".gif", ".webp", ".mp4", ".pdf", ".zip"]
  },

  "Notifications": {
    "Firebase": {
      "ProjectId": "",
      "CredentialsPath": "firebase-credentials.json"
    }
  },

  "AllowedOrigins": [
    "http://localhost:3000",
    "http://localhost:5173"
  ],

  "AllowedHosts": "*"
}
