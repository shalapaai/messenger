{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore":                  "Warning",
        "Microsoft.EntityFrameworkCore":         "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System.Net.Http.HttpClient":            "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/messenger-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },

  "ConnectionStrings": {
    "MessengerDb": "Host=localhost;Port=5432;Database=messenger;Username=messenger;Password=messenger_dev;Pooling=true;MinPoolSize=5;MaxPoolSize=50"
  },

  "Redis": {
    "ConnectionString": "localhost:6379,password=redis_dev,abortConnect=false,connectTimeout=5000,syncTimeout=5000,keepAlive=60"
  },

  "Jwt": {
    "SecretKey": "dev-secret-key-minimum-32-chars-replace-in-production!!",
    "Issuer": "Messenger.Api",
    "Audience": "Messenger.Client",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },

  "FileStorage": {
    "Type": "Local",
    "Local": {
      "BasePath": "/var/messenger/uploads",
      "BaseUrl": "/api/files"
    },
    "S3": {
      "BucketName": "",
      "Region": "eu-central-1",
      "CdnBaseUrl": ""
    }
  },

  "Localization": {
    "DefaultCulture": "en",
    "SupportedCultures": ["en", "ru"]
  },

  "AllowedOrigins": [
    "http://localhost:3000",
    "http://localhost:5173"
  ],

  "TwoFactor": {
    "Enabled": true
  },

  "PasswordReset": {
    "Enabled": true
  },

  "Resend": {
    "ApiKey": "",
    "FromEmail": "onboarding@resend.dev"
  },

  "AllowedHosts": "*"
}
