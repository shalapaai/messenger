# Скопируй в .env и заполни значения: cp .env.example .env

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=messenger
POSTGRES_PASSWORD=messenger_dev_password_change_in_prod
POSTGRES_DB=messenger
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_dev_password_change_in_prod
REDIS_PORT=6379

# ── pgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ── Application ───────────────────────────────────────────────────────────────
API_PORT=8080
FRONTEND_PORT=5173     # 5173 в dev (Vite), 3000 в prod (nginx)
ASPNETCORE_ENVIRONMENT=Development

# JWT — минимум 256 бит (32 символа), менять в prod
JWT_SECRET_KEY=dev-secret-key-32-chars-minimum!!
JWT_ISSUER=Messenger.Api
JWT_AUDIENCE=Messenger.Client

# File Storage: Local | S3
FILE_STORAGE_TYPE=Local

# S3 (заполнить при FILE_STORAGE_TYPE=S3)
# S3_BUCKET_NAME=
# S3_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Resend (отправка email — OTP, сброс пароля). Без ключа письма просто не уходят.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Web Push (VAPID) — сгенерировать: npx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
